FROM gradle:8.7-jdk21 AS builder
WORKDIR /app
COPY . .

RUN ./gradlew clean --refresh-dependencies --no-daemon
RUN ./gradlew :cli-native:jvmJar  --no-daemon --console=plain

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app

ENV YANDEX_CLIENT_ID=${YANDEX_CLIENT_ID}

COPY --from=builder /app/cli-native/build/libs/*.jar /app/app.jar

RUN addgroup -S appgroup && adduser -S appuser -G appgroup

RUN mkdir -p /credentials /data

RUN apk add --no-cache su-exec

RUN cat > /docker-entrypoint.sh <<EOF
  chown -R appuser:appgroup /data /credentials 2>/dev/null || true
  exec su-exec appuser java $JAVA_OPTS -jar /app/app.jar "$@"
EOF
RUN chmod +x /docker-entrypoint.sh

ENV JAVA_OPTS="-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0"

ENTRYPOINT ["/docker-entrypoint.sh"]